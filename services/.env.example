# === Polymarket CLOB Credentials ===

# Wallet type: "magic" for email/Magic Link, "eoa" for MetaMask/private key
POLY_WALLET_TYPE=magic

# Your Magic Link derived private key
# Extract from browser: Polymarket > DevTools > Application > Local Storage
# Look for "magic_auth" or export via Magic SDK
POLY_PRIVATE_KEY=0x...your_magic_private_key...

# Your Polymarket proxy/funder address (shown on your profile page)
# This is the address that holds your USDC on Polygon
POLY_FUNDER=0x...your_funder_address...

# API credentials (leave empty to auto-derive on first run)
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# === Bot Config Paths (optional) ===
BOT_CONFIG=config/bot.yaml
MARKETS_CONFIG=config/markets.yaml
